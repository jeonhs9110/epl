# ── Trained model weights (too large for git) ─────────────────────────────────
models/*.pth
models/*.joblib
models/xgb_classifier.json

# ── Encoder pickle (regenerated on first run) ──────────────────────────────────
encoders.pkl

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Scraper browser/debug artefacts (root-level only) ─────────────────────────
# Note: templates/**/*.html are Jinja2 source files — kept tracked below
/*.html
/*.png

# ── Jinja2 templates (source code — always track) ─────────────────────────────
!templates/
!templates/**

# ── User-generated runtime data ───────────────────────────────────────────────
bet_history.json
training_history.json

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Sensitive / personal ──────────────────────────────────────────────────────
.env
