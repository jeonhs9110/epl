# Copy this file to `.env` next to app.py and fill in your values.
# The .env file is gitignored — never commit real keys.
#
# To activate the chatbot features (match report + picks advisor), set:
OPENAI_API_KEY=sk-...

# Optional: which model the chatbot uses (default: gpt-4o-mini — cheap + fast).
# Any OpenAI chat model works: gpt-4o, gpt-4o-mini, gpt-4.1-mini, o3-mini, etc.
OPENAI_MODEL=gpt-4o-mini
